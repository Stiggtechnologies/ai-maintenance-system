# SyncAI Production Environment Variables
# Copy to .env.production and fill in values from .credentials-vault.env

# ============================================
# SUPABASE (Get from Supabase Dashboard)
# ============================================
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ============================================
# OPENAI API (Use Axium key from credentials vault)
# ============================================
# NOTE: This should be set in Supabase Edge Function secrets, NOT here
# OPENAI_API_KEY will be accessed server-side only
# Value: OPENAI_API_KEY_AXIUM from .credentials-vault.env

# ============================================
# STRIPE (Use test keys for staging, live for production)
# ============================================
# TEST KEYS (from credentials vault)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Secret key goes in Supabase Edge Function secrets
# STRIPE_SECRET_KEY (server-side only)
# Value: STRIPE_SECRET_KEY_TEST from .credentials-vault.env

# ============================================
# TWILIO (Optional - for SMS alerts)
# ============================================
# Set in Supabase Edge Function secrets if needed
# TWILIO_API_KEY from .credentials-vault.env

# ============================================
# AZURE AD SSO (Required for Azure Marketplace)
# ============================================
# Register SyncAI as multi-tenant app at portal.azure.com > App registrations
VITE_AZURE_AD_CLIENT_ID=your_azure_ad_app_client_id
VITE_AZURE_AD_TENANT_ID=common
VITE_AZURE_AD_REDIRECT_URI=https://app.syncai.ca/auth/callback/azure

# Azure AD secrets go in Supabase Edge Function secrets:
# AZURE_AD_CLIENT_ID=same_as_above
# AZURE_AD_CLIENT_SECRET=your_azure_ad_client_secret
# AZURE_AD_TENANT_ID=your_primary_tenant_id

# ============================================
# DEPLOYMENT
# ============================================
VITE_APP_URL=https://app.syncai.ca
VITE_ENVIRONMENT=production
