# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe (publishable key only - secret key goes in Supabase Edge Function secrets)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Google Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Demo credentials (optional - only set for staging/demo environments)
# VITE_DEMO_EMAIL=
# VITE_DEMO_PASSWORD=

# App
VITE_APP_URL=http://localhost:5173
VITE_ENVIRONMENT=development

# Note: Never commit .env files to version control
# For production, set these as environment variables in your hosting platform
